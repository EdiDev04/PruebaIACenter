{
  "openapi": "3.0.1",
  "info": {
    "title": "Cotizador de Daños API",
    "description": "API REST del Cotizador de Seguros de Daños a la Propiedad. Gestiona folios, datos generales, ubicaciones de riesgo, opciones de cobertura y cálculo de primas.",
    "contact": {
      "name": "Equipo Cotizador",
      "email": "cotizador@empresa.com"
    },
    "version": "v1"
  },
  "paths": {
    "/v1/subscribers": {
      "get": {
        "tags": [
          "Catalog"
        ],
        "summary": "GET /v1/subscribers — Obtiene el catálogo de suscriptores desde core-ohs.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/agents": {
      "get": {
        "tags": [
          "Catalog"
        ],
        "summary": "GET /v1/agents?code=AGT-001 — Obtiene un agente por código desde core-ohs.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
